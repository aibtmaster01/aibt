// 배포: firebase deploy --only firestore:rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // users 컬렉션: 본인 문서는 읽기/쓰기, 관리자(isAdmin)는 모든 회원 문서 읽기·쓰기 가능 (회원관리 사용정지/해제, 결제 수정 등)
    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
             || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true);
      allow write: if request.auth != null
        && (request.auth.uid == userId
             || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
                 && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true));
    }
    // 본인 하위 컬렉션만 (exam_results, stats, user_weakness_stats 등). 관리자(isAdmin)는 다른 사용자 하위 컬렉션 읽기 가능 (Admin 페이지 푼 문제 수 등)
    match /users/{userId}/{document=**} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
             || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // certifications: 관리자는 certification_info/config 시험일정 수정 가능 (자격증 관리 페이지)
    // exists()로 사용자 문서 존재 시에만 get() 호출해 권한 오류 방지
    match /certifications/{certCode}/certification_info/config {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }
    // certifications/question_pools/.../questions: 관리자 문제 수정 (문제관리 화면)
    match /certifications/{certCode}/question_pools/{poolId}/questions/{questionId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }
    // certifications 나머지: 읽기만
    match /certifications/{path=**} {
      allow read: if true;
      allow write: if false;
    }
    // collection group 'questions' 쿼리: 재귀 와일드카드는 반드시 최상위에 (match /{path=**}/questions/...)
    match /{path=**}/questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    // daily_visits: 로그인 사용자 방문 기록 (Admin 통계용). 본인은 자신만 쓰기, 관리자는 전체 읽기
    match /daily_visits/{date}/users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid
             || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
                 && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true));
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // error_logs: 클라이언트 오류 기록 (대시보드 오류 로그 영역). 로그인 사용자 생성, 관리자만 읽기
    match /error_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
      allow update, delete: if false;
    }
    match /coupon_redemptions/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
      allow update, delete: if false;
    }
    // 베타 쿠폰: 로그인 사용자가 조회(검증)·업데이트(사용 처리)만 가능. 생성/삭제는 콘솔 또는 스크립트로 (beta_coupon.csv 기반)
    match /beta_coupons/{code} {
      allow read, update: if request.auth != null;
      allow create, delete: if false;
    }
  }
}
