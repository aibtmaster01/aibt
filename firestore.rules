// 배포: firebase deploy --only firestore:rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // users 컬렉션: 본인 문서는 읽기/쓰기, 관리자(isAdmin)는 모든 회원 문서 읽기 가능 (Admin 페이지 스냅샷 리스너)
    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
             || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true);
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // 본인 하위 컬렉션만 (exam_results, stats, user_weakness_stats 등). 관리자(isAdmin)는 다른 사용자 하위 컬렉션 읽기 가능 (Admin 페이지 푼 문제 수 등)
    match /users/{userId}/{document=**} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
             || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // certifications: static_exams, certification_info 등 (단일 문서/서브컬렉션 읽기)
    match /certifications/{path=**} {
      allow read: if true;
      allow write: if false;
    }
    // collection group 'questions' 쿼리: 재귀 와일드카드는 반드시 최상위에 (match /{path=**}/questions/...)
    match /{path=**}/questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    // daily_visits: 로그인 사용자 방문 기록 (Admin 통계용)
    match /daily_visits/{date}/users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
